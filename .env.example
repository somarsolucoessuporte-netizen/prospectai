# =============================================================
# ProspectAI — Variaveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o arquivo .env.local
# =============================================================

# Supabase — https://supabase.com/dashboard/project/SEU_PROJETO/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Database — Supabase > Settings > Database > Connection string
# Use "Transaction" para DATABASE_URL (pooler) e "Session" para DIRECT_URL
DATABASE_URL=postgresql://postgres.SEU_PROJETO:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.SEU_PROJETO:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Groq (IA gratuita — Llama 3) — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# Worker — secret para proteger o endpoint /api/worker
WORKER_SECRET=

# OpenStreetMap — sem chave necessaria
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter

# APIs externas (serao usadas nas proximas fases)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
